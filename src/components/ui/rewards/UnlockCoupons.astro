---
import "../../../styles/global.css"
---

<section class="space-y-4">
    <h3 class="text-xl font-bold text-primary">Tus Recompensas</h3>
    <div class="grid grid-cols-1 gap-4">
        <div
            class="flex bg-surface-container-low rounded-2xl overflow-hidden shadow-sm group"
        >
            <div class="w-1/3 relative">
                <img
                    class="h-full w-full object-cover"
                    data-alt="exquisite fine dining plate with artistic plating and vibrant colors in a dimly lit restaurant"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuCvyiKzgCrbMtUJ6eRx5jQh3mcTUztwxqA5T-aI_z58J85VYA7-9OfMiZjL8FJxkzNon7DISG_y5ycY4nx3Uv9ndAK-gjHSRgDFWP8Fujrg2EdwVNPZniYxKkW-ZqMNQkb3R7K1c9aj4CJNi2Jog1yitgJZ2Bpq0IFgLv80XYW9EI_KayhmenC6UkAXMEriIxvdo42FpJoXJJQxH9Uo3sbLQe5oDw2QJUN3TywsEPV2D3Q8WOV-0iQFo6mqvuGNgYJEFicalGAerNk"
                />
                <div class="absolute inset-0 bg-primary/20"></div>
            </div>
            <div class="flex-1 p-5 flex flex-col justify-center">
                <h4
                    class="text-primary font-bold text-lg leading-tight"
                >
                    15% OFF en El Cielo
                </h4>
                <p class="text-on-surface-variant text-xs mt-1">
                    Vence en 3 días • Cena Gourmet
                </p>
            </div>
        </div>
        <div
            class="flex bg-surface-container-low rounded-2xl overflow-hidden shadow-sm"
        >
            <div class="w-1/3 relative">
                <img
                    class="h-full w-full object-cover"
                    data-alt="freshly brewed coffee in a ceramic cup with latte art on a wooden table with soft afternoon sun"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuDmiedBHLdIlOfZLc7Ck8Ui_GbljEnadfeUbaUxrQ9gRTyBEgY-DkOuJwNyaz0n599isZiQiS2bYT2HzTEH42uUgVQ9bYk54DbQB9zI0VmmpcAg6U36F030brmSEpkjuLBmvpIFWWfGYXgczNmRVJaIdtdOPGD9ITIImV29oQK-BVxSCZz7Ffm1Af42d9x8U4M_-Y4ZcgaAdFXls1lEN-5UWca0eN8wvqZ8wVrAOERWE2XvxyA5p0Jrlmhpo3nT8TwJHZgOP2BEKTk"
                />
                <div class="absolute inset-0 bg-primary/20"></div>
            </div>
            <div class="flex-1 p-5 flex flex-col justify-center">
                <h4
                    class="text-primary font-bold text-lg leading-tight"
                >
                    Café de Origen Gratis
                </h4>
                <p class="text-on-surface-variant text-xs mt-1">
                    Válido en: Pergamino Café
                </p>
            </div>
        </div>
    </div>
</section>