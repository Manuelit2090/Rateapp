---
import "../../styles/global.css";

const {
    restaurantName,
    restaurantImage,
    restaurantDescription
} = Astro.props;
---



<div
    class="flex-none w-75 relative aspect-16/10 rounded-2xl overflow-hidden shadow-lg group"
>
    <img
        alt={restaurantName}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        src={restaurantImage}
    />
    <div class="absolute top-2 left-2">
        <span
            class="bg-terciary/85 p-1 rounded-2xl text-white font-bold text-xs uppercase tracking-wider"
            >Patrocinado</span
        >
    </div>
    <div
        class="absolute inset-0 bg-linear-to-t from-black/70 via-transparent to-transparent"
    >
    </div>
    <div class="absolute bottom-4 left-4 right-4">
        <h3 class="text-white font-headline font-bold text-lg">
            {restaurantName}
        </h3>
        <p class="text-white/80 text-xs">{restaurantDescription}</p>
    </div>
</div>
