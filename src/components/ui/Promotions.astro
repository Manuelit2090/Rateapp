---
import "../../styles/global.css";
import promotions from "../../data/promotions.json";
---

<div class="w-full">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {
      promotions.map((promotion) => (
        <div class="relative rounded-2xl overflow-hidden h-64 group cursor-pointer">
          {/* Imagen de fondo */}
          <img
            src={promotion.image}
            alt={promotion.title}
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          />
          
          {/* Overlay oscuro en la parte inferior */}
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4 h-1/2 flex flex-col justify-end">
            <h3 class="text-white font-bold text-lg mb-1">
              {promotion.title}
            </h3>
            <p class="text-gray-200 text-sm line-clamp-2">
              {promotion.description}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</div>
