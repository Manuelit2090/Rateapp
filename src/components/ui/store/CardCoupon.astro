---
import "../../../styles/global.css";

const {
    couponName,
    couponDescription,
    pointsRequired,
    couponImage,
    couponCategory
} = Astro.props;
---

<div
    class="bg-surface-container-lowest rounded-3xl p-5 flex flex-col md:flex-row gap-6 shadow-[0px_12px_32px_rgba(28,28,23,0.06)] group hover:shadow-[0px_16px_48px_rgba(28,28,23,0.1)] transition-all duration-300"
>
    <div class="shrink-0 w-full md:w-40 h-40 rounded-2xl overflow-hidden">
        <img
            alt="El Cielo Dish"
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            data-alt="Exquisite fine dining dish with edible flowers and molecular gastronomy foam on a dark artistic ceramic plate"
            src={couponImage}
        />
    </div>
    <div class="grow flex flex-col justify-between">
        <div>
            <div class="flex justify-between items-start mb-2">
                <h4 class="text-lg font-headline font-bold text-on-surface">
                    {couponName}
                </h4>
                <div 
                class="px-3 py-1 bg-secondary text-on-secondary text-[10px] font-extrabold uppercase rounded-full">
                {couponCategory}
            </div>
            </div>
            <p class="text-on-surface-variant text-sm leading-relaxed mb-4">
                {couponDescription}
            </p>
        </div>
        <div class="flex items-center justify-between mt-auto">
            <div class="flex items-center gap-1.5 text-primary">
                <span
                    class="material-symbols-outlined text-xl"
                    data-icon="confirmation_number">confirmation_number</span
                >
                <span class="font-headline font-bold">{pointsRequired} Puntos</span>
            </div>
           
            <button
                class="bg-linear-to-br from-[#005056] to-[#006a71] text-white px-8 py-3 rounded-2xl font-label text-xs font-bold uppercase tracking-widest shadow-lg active:scale-95 transition-all"
                >Canjear</button
            >
        </div>
    </div>
</div>
