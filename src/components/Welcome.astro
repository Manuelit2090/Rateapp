---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
import '../styles/global.css'
---
<!DOCTYPE html>
<html class="light" lang="es">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>RateApp</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
  
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  
  <style>
    /* Utilidades personalizadas que Tailwind no cubre por defecto de forma nativa */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    body { min-height: 100dvh; }
  </style>
</head>

<body class="bg-bg text-on-surface font-body max-w-auto  mx-auto overflow-x-hidden pb-24 ">

  <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 py-4 bg-surface/80 backdrop-blur-md shadow-sm">
    <div class="flex items-center gap-1">
      <span class="material-symbols-outlined text-primary text-xl">location_on</span>
      <span class="text-sm font-headline font-bold text-primary">Medellín, CO</span>
    </div>
    <h1 class="text-xl font-extrabold text-primary font-headline tracking-tight">GastroLink</h1>
    <button class="active:scale-95 transition-transform">
      <span class="material-symbols-outlined text-primary">favorite</span>
    </button>
  </header>

  <main class="mt-20 px-4 space-y-8 pb-24">
    
    <section>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-secondary">search</span>
        <input type="text" placeholder="Encuentra tu próximo antojo" 
               class="w-full bg-surface-container py-4 pl-12 pr-4 rounded-full border-none focus:ring-2 focus:ring-primary/20 placeholder:text-stone-400 font-medium shadow-sm transition-all"/>
      </div>
    </section>

    <section class="flex gap-3 overflow-x-auto no-scrollbar -mx-4 px-4">
      <button class="flex-none px-6 py-2 bg-secondary text-white rounded-full font-headline font-semibold text-sm shadow-md active:scale-95">Restaurantes</button>
      <button class="flex-none px-6 py-2 bg-surface-container-high text-on-surface-variant rounded-full font-headline font-semibold text-sm active:scale-95">Cafeterías</button>
      <button class="flex-none px-6 py-2 bg-surface-container-high text-on-surface-variant rounded-full font-headline font-semibold text-sm active:scale-95">Bares</button>
      <button class="flex-none px-6 py-2 bg-surface-container-high text-on-surface-variant rounded-full font-headline font-semibold text-sm active:scale-95">Postres</button>
    </section>

    <section class="space-y-4">
      <div class="flex justify-between items-end">
        <h2 class="text-2xl font-headline font-bold text-on-surface">Recomendados</h2>
        <button class="text-secondary font-semibold text-sm">Ver todos</button>
      </div>
      
      <div class="flex gap-5 overflow-x-auto no-scrollbar -mx-4 px-4 pb-4">
        <div class="flex-none w-[280px] relative aspect-[4/5] rounded-[2rem] overflow-hidden group shadow-xl">
          <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=500" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Burger">
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent"></div>
          <div class="absolute top-4 left-4 bg-primary text-white px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase">NUEVO</div>
          <div class="absolute bottom-6 left-6 text-white">
            <div class="flex items-center gap-1 bg-white/20 backdrop-blur-md px-2 py-0.5 rounded mb-2 w-fit">
              <span class="material-symbols-outlined text-yellow-400 text-sm" style="font-variation-settings: 'FILL' 1">star</span>
              <span class="text-xs font-bold">4.9</span>
            </div>
            <h3 class="text-xl font-headline font-extrabold leading-tight">Burger Masterpiece</h3>
            <p class="text-white/80 text-sm">Bistró Contemporáneo</p>
          </div>
        </div>
        <div class="flex-none w-[280px] relative aspect-[4/5] rounded-[2rem] overflow-hidden group shadow-xl">
          <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?q=80&w=500" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Dining">
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent"></div>
          <div class="absolute bottom-6 left-6 text-white">
            <h3 class="text-xl font-headline font-extrabold leading-tight">Mar & Tierra Fusion</h3>
            <p class="text-white/80 text-sm">Experiencia Gourmet</p>
          </div>
        </div>
      </div>
    </section>

    <section class="space-y-6 pb-12">
      <h2 class="text-2xl font-headline font-bold text-on-surface">Cerca de ti</h2>
      
      <div class="space-y-4">
        <div class="relative aspect-video rounded-[1.5rem] overflow-hidden">
          <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=600" class="w-full h-full object-cover" alt="Restaurant">
          <button class="absolute top-4 right-4 w-10 h-10 bg-white/90 rounded-full flex items-center justify-center text-primary shadow-sm active:scale-90 transition-transform">
            <span class="material-symbols-outlined">favorite</span>
          </button>
        </div>
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-lg font-headline font-bold">El Cielo Cocina</h3>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs font-semibold text-secondary px-2 py-0.5 bg-secondary/10 rounded-full">Fusion Gourmet</span>
              <span class="text-xs text-stone-500">• 1.2km</span>
            </div>
          </div>
          <button class="bg-primary text-white px-5 py-2.5 rounded-full text-xs font-bold uppercase shadow-lg shadow-primary/20 active:scale-95 transition-transform">Ver oferta</button>
        </div>
      </div>
    </section>
  </main>

  <button class="fixed bottom-28 right-6 w-14 h-14 bg-secondary text-white rounded-2xl flex items-center justify-center shadow-lg z-40 active:scale-90 transition-transform">
    <span class="material-symbols-outlined text-3xl">map</span>
  </button>

  <nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-surface/90 backdrop-blur-xl border-t border-stone-200/20 shadow-2xl rounded-t-[2rem]">
    <a href="#" class="flex flex-col items-center text-primary bg-primary/5 px-4 py-1 rounded-full">
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">home</span>
      <span class="text-[10px] font-bold uppercase mt-0.5">Home</span>
    </a>
    <a href="#" class="flex flex-col items-center text-stone-400 hover:text-primary transition-colors">
      <span class="material-symbols-outlined">map</span>
      <span class="text-[10px] font-bold uppercase mt-0.5">Mapa</span>
    </a>
    <a href="#" class="flex flex-col items-center text-stone-400 hover:text-primary transition-colors">
      <span class="material-symbols-outlined">emoji_events</span>
      <span class="text-[10px] font-bold uppercase mt-0.5">Premios</span>
    </a>
    <a href="#" class="flex flex-col items-center text-stone-400 hover:text-primary transition-colors">
      <span class="material-symbols-outlined">person</span>
      <span class="text-[10px] font-bold uppercase mt-0.5">Perfil</span>
    </a>
  </nav>

</body>
</html>