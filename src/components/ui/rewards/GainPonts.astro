---
import "../../../styles/global.css"
---

     <section
                class="bg-surface-container-highest/30 rounded-4xl p-6 space-y-6"
            >
                <h3 class="text-xl font-bold text-primary">Cómo ganar más</h3>
                <div class="space-y-4">
                    <div
                        class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-sm"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center text-primary"
                        >
                            <span class="material-symbols-outlined"
                                >rate_review</span
                            >
                        </div>
                        <div class="flex-1">
                            <p class="font-bold text-primary">Reseñas</p>
                            <p
                                class="text-[10px] text-on-surface-variant uppercase tracking-wider"
                            >
                                +50 Puntos por visita
                            </p>
                        </div>
                        <span
                            class="material-symbols-outlined text-secondary text-sm"
                            >chevron_right</span
                        >
                    </div>
                    <div
                        class="flex items-center gap-4 bg-white p-4 rounded-xl shadow-sm"
                    >
                        <div
                            class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center text-primary"
                        >
                            <span class="material-symbols-outlined"
                                >group_add</span
                            >
                        </div>
                        <div class="flex-1">
                            <p class="font-bold text-primary">Invita</p>
                            <p
                                class="text-[10px] text-on-surface-variant uppercase tracking-wider"
                            >
                                +200 Puntos por amigo
                            </p>
                        </div>
                        <span
                            class="material-symbols-outlined text-secondary text-sm"
                            >chevron_right</span
                        >
                    </div>
               
                </div>
            </section>