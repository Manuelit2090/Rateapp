---
import "../../../styles/global.css"
---

   <section
                class="relative overflow-hidden rounded-4xl bg-fourty p-8 text-white shadow-2xl"
            >
            
                <div
                    class="absolute -top-12 -right-12 w-48 h-48 bg-white/5 rounded-full blur-3xl"
                >
                </div>
                <div
                    class="relative z-10 flex flex-col items-center text-center"
                >
                    <div class="relative mb-6">
                        <!-- Circular Progress -->
                        <svg class="w-32 h-32 transform -rotate-90">
                            <circle
                                class="text-white/10"
                                cx="64"
                                cy="64"
                                fill="transparent"
                                r="58"
                                stroke="currentColor"
                                stroke-width="6"></circle>
                            <circle
                                class="text-secondary-fixed"
                                cx="64"
                                cy="64"
                                fill="transparent"
                                r="58"
                                stroke="currentColor"
                                stroke-dasharray="364.4"
                                stroke-dashoffset="91.1"
                                stroke-linecap="round"
                                stroke-width="8"></circle>
                        </svg>
                        <div
                            class="absolute inset-0 flex flex-col items-center justify-center"
                        >
                            <span
                                class="material-symbols-outlined text-secondary-fixed text-4xl"
                                style="font-variation-settings: 'FILL' 1;"
                                >stars</span
                            >
                        </div>
                    </div>
                    <h2 class="text-4xl font-extrabold mb-1 tracking-tight">
                        2,450 Puntos
                    </h2>
                    <p
                        class="text-secondary-fixed/80 text-sm font-medium uppercase tracking-widest mb-6"
                    >
                        Nivel actual: Gourmet
                    </p>
                    <div class="w-full h-px bg-white/10 mb-6"></div>
                    <div class="flex items-center gap-3">
                        <div class="flex -space-x-2">
                            <div
                                class="w-8 h-8 rounded-full border-2 border-fourty bg-surface-variant overflow-hidden"
                            >
                                <img
                                    class="w-full h-full object-cover"
                                    data-alt="portrait of a young man with a friendly smile in warm natural lighting"
                                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuCP5kvFxI6_s5hDo7x7J9xFOgx-TxcIyxPLQQQ7CNwRwxmDhv0RNls2hBwOLTBv7xdzjHSxfmGULpQQk6Lpi6xai6Hn3P6MXyEa9ucCh5v5nIIKLrp0HRUPwkS2hYhPmosWWS5Hrii0Rcq5Q9kDgbBF1xNIjbD9mYoG0_3euhl8amUid_R0-7KoD_WJmyN612FttnBYFjgbisVTet7rLX3F9nRYbyZaJvQFIuoTPdVKU1Gre2YWIts1WoMCfowoYeO21W3Zuj5VP0o"
                                />
                            </div>
                            <div
                                class="w-8 h-8 rounded-full border-2 border-fourty bg-surface-variant flex items-center justify-center"
                            >
                                <span
                                    class="material-symbols-outlined text-[10px] text-primary"
                                    >add</span
                                >
                            </div>
                        </div>
                        <p class="text-xs text-white/70">
                            Próximo Nivel: <span
                                class="text-white font-bold italic"
                                >Explorador de Sabores</span>
                        </p>
                    </div>
                </div>
            </section>